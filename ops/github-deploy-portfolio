#!/usr/bin/env bash

set -Eeuo pipefail

readonly repo_dir="/home/vloth/prod/apps/portfolio-next"
readonly compose_file="docker-compose.prod.yml"
readonly lock_file="/home/vloth/prod/apps/.portfolio-next-deploy.lock"

deploy_command="${SSH_ORIGINAL_COMMAND:-${*:-}}"
if [[ ! "$deploy_command" =~ ^deploy[[:space:]]+([0-9a-f]{40})$ ]]; then
  echo "Only 'deploy <git-sha>' is allowed." >&2
  exit 64
fi
readonly deploy_sha="${BASH_REMATCH[1]}"

exec 9>"$lock_file"
if ! flock -n 9; then
  echo "Another production deployment is already running." >&2
  exit 75
fi

cd "$repo_dir"

show_diagnostics() {
  exit_code=$?
  echo "Deployment failed with exit code $exit_code." >&2
  docker compose -f "$compose_file" ps >&2 || true
  docker compose -f "$compose_file" logs --tail=80 >&2 || true
  exit "$exit_code"
}
trap show_diagnostics ERR

git fetch --prune origin main
git cat-file -e "${deploy_sha}^{commit}"

if ! git merge-base --is-ancestor "$deploy_sha" origin/main; then
  echo "Revision $deploy_sha is not contained in origin/main." >&2
  exit 65
fi

readonly current_sha="$(git rev-parse HEAD)"

git merge --ff-only "$deploy_sha"
docker compose -f "$compose_file" config --quiet

changed_files="$(git diff --name-only "$current_sha" "$deploy_sha")"
full_deploy=false
build_services=()
up_services=()
services=()

changes_match() {
  local pattern="$1"
  grep -Eq "$pattern" <<<"$changed_files"
}

append_unique() {
  local item="$1"
  shift
  local -n target_array="$1"

  for existing in "${target_array[@]}"; do
    if [[ "$existing" == "$item" ]]; then
      return
    fi
  done

  target_array+=("$item")
}

append_build_service() {
  local service="$1"
  append_unique "$service" build_services
  append_unique "$service" up_services
  append_unique "$service" services
}

append_up_service() {
  local service="$1"
  append_unique "$service" up_services
  append_unique "$service" services
}

if changes_match '^docker-compose\.prod\.yml$'; then
  full_deploy=true
fi

if [[ "$full_deploy" == true ]]; then
  echo "Runtime changes require a full production deploy."
  COMPOSE_BAKE=false docker compose -f "$compose_file" up -d --build
  services=(postgres chatbot_backend strapi frontend gateway)
else
  if changes_match '^frontend/'; then
    append_build_service frontend
  fi

  if changes_match '^chatbot_backend/'; then
    append_build_service chatbot_backend
  fi

  if changes_match '^cms/strapi/'; then
    append_build_service strapi
  fi

  if changes_match '^gateway/'; then
    append_up_service gateway
  fi

  if ((${#build_services[@]} > 0)); then
    echo "Building changed services: ${build_services[*]}"
    COMPOSE_BAKE=false docker compose -f "$compose_file" build "${build_services[@]}"
  fi

  if ((${#up_services[@]} > 0)); then
    echo "Recreating changed services: ${up_services[*]}"
    COMPOSE_BAKE=false docker compose -f "$compose_file" up -d --no-deps "${up_services[@]}"
  else
    echo "No runtime service changes detected; skipping container rebuild."
    services=(gateway)
  fi
fi

deadline=$((SECONDS + 240))

for service in "${services[@]}"; do
  container_id="$(docker compose -f "$compose_file" ps -q "$service")"
  if [[ -z "$container_id" ]]; then
    echo "No container found for service $service." >&2
    exit 1
  fi

  while true; do
    status="$(
      docker inspect \
        --format '{{if .State.Health}}{{.State.Health.Status}}{{else}}{{.State.Status}}{{end}}' \
        "$container_id"
    )"

    case "$status" in
      healthy | running)
        break
        ;;
      unhealthy | exited | dead)
        echo "Service $service entered state $status." >&2
        exit 1
        ;;
    esac

    if ((SECONDS >= deadline)); then
      echo "Timed out waiting for service $service (state: $status)." >&2
      exit 1
    fi

    sleep 3
  done
done

docker exec portfolio-next-gateway \
  wget -qO- http://127.0.0.1/gateway-health |
  grep -qx "ok"

echo "Production deployed at revision $deploy_sha."
docker compose -f "$compose_file" ps
