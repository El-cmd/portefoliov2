# Local Nginx gateway
GATEWAY_PORT=8080

# Groq chatbot
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=openai/gpt-oss-120b
GROQ_TEMPERATURE=0.1
GROQ_TIMEOUT_SECONDS=25
GROQ_MAX_CONCURRENT_REQUESTS=2
GROQ_QUEUE_TIMEOUT_SECONDS=5
PROMPT_GUARD_ENABLED=true
PROMPT_GUARD_PRIMARY_MODEL=meta-llama/llama-prompt-guard-2-86m
PROMPT_GUARD_FALLBACK_MODEL=meta-llama/llama-prompt-guard-2-22m
PROMPT_GUARD_TIMEOUT_SECONDS=3
PROMPT_GUARD_MALICIOUS_THRESHOLD=0.5
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
CHAT_STRUCTURED_OUTPUT=true
CHAT_DEBUG_LOG=false
KB_DIR=./kb_faiss
# KB_INDEX_PATH=./kb_faiss/kb.index.faiss
# KB_META_PATH=./kb_faiss/kb.index.meta.json
KB_TOP_K=4
KB_MIN_SCORE=0.2
CHATBOT_INTERNAL_URL=http://chatbot_backend:8001
BACKEND_TIMEOUT_MS=30000
CHAT_RATE_LIMIT_ENABLED=true
CHAT_RATE_LIMIT_REQUESTS_PER_MINUTE=5
CHAT_RATE_LIMIT_BURST=3
CHAT_RATE_LIMIT_TRUST_PROXY_HEADERS=true

# Strapi CMS
# Optional read-only token used server-side by the Next frontend if Public permissions are closed.
STRAPI_API_TOKEN=
STRAPI_PUBLIC_URL=https://cms.vloth.tech
STRAPI_APP_KEYS=replace_me_1,replace_me_2,replace_me_3,replace_me_4
STRAPI_API_TOKEN_SALT=replace_me
STRAPI_ADMIN_JWT_SECRET=replace_me
STRAPI_TRANSFER_TOKEN_SALT=replace_me
STRAPI_JWT_SECRET=replace_me
STRAPI_ENCRYPTION_KEY=replace_me
STRAPI_DATABASE_NAME=strapi
STRAPI_DATABASE_USERNAME=strapi
STRAPI_DATABASE_PASSWORD=strapi
STRAPI_DATABASE_SSL=false
